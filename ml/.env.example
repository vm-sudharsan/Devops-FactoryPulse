# =============================================================================
# FACTORY PULSE — ML SERVICE ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# Local / Docker: 5001
# Kubernetes:     Render injects $PORT automatically
# -----------------------------------------------------------------------------
PORT=5001

# -----------------------------------------------------------------------------
# Flask environment
# development  → enables debug mode and auto-reload (DO NOT use in production)
# production   → disables debug mode
# -----------------------------------------------------------------------------
FLASK_ENV=production

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins.
# The ML service is called server-to-server (backend → ML), so this only
# matters if the ML service is ever called directly from a browser.
# Local:      http://localhost:8070,http://localhost:3001
# Docker:     http://backend:8070
# Production: https://api.yourdomain.com
# -----------------------------------------------------------------------------
# Frontend origin only — backend→ML is server-to-server, CORS does not apply there.
# Local:        http://localhost:3001
# Docker:       http://localhost:3001
# Kubernetes:   https://yourdomain.com
CORS_ORIGINS=http://localhost:3001
