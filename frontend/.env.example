# =============================================================================
# FACTORY PULSE — FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values for your environment.
# IMPORTANT: VITE_* variables are baked into the JS bundle at build time.
#            You must set the correct value BEFORE running `npm run build`.
# =============================================================================

# Backend API base URL (no trailing slash)
# Local development:   http://localhost:8070
# Docker Compose:      http://localhost:8070
# Kubernetes / AWS:    https://api.yourdomain.com
VITE_API_URL=http://localhost:8070

# Application display name
VITE_APP_NAME=FactoryPulse

# Vite dev server port (only used by `npm run dev`, not baked into build)
# Default: 3001
VITE_PORT=3001
