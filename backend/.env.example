# =============================================================================
# FACTORY PULSE — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8070
NODE_ENV=production

# -----------------------------------------------------------------------------
# Database
# Set DB_TYPE to either: mongodb  or  postgresql
# -----------------------------------------------------------------------------
DB_TYPE=mongodb

# MongoDB Atlas connection string
MONGODB_URI=your_mongodb_atlas_connection_string

# PostgreSQL (only required when DB_TYPE=postgresql)
POSTGRES_HOST=your_postgres_host
POSTGRES_PORT=5432
POSTGRES_DB=factorypulse
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins (no trailing slashes)
# Local:      http://localhost:3001
# Docker:     http://localhost:3001
# Production: https://yourdomain.com
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# ThingSpeak IoT
# -----------------------------------------------------------------------------
THINGSPEAK_CHANNEL_ID=your_thingspeak_channel_id
THINGSPEAK_READ_API_KEY=your_thingspeak_read_api_key
THINGSPEAK_WRITE_API_KEY=your_thingspeak_write_api_key
THINGSPEAK_FETCH_INTERVAL=60000

# -----------------------------------------------------------------------------
# JWT Authentication
# Generate secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=your_secure_jwt_secret_minimum_32_characters
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# ML Service
# Local:      http://localhost:5001
# Docker:     http://ml:5001
# Kubernetes: http://ml-service:5001
# -----------------------------------------------------------------------------
ML_SERVICE_URL=http://localhost:5001
ML_TIMEOUT=120000
